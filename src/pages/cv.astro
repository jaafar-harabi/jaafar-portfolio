---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  {/* Profile */}
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify leading-relaxed max-w-4xl">
    <p class="mb-3">
      Cloud & DevOps Engineer with <strong>3+ years</strong> of experience designing
      and operating cloud-native and hybrid infrastructures (AWS + on-prem).
    </p>
    <p class="mb-3">
      I specialize in building reliable, secure, and scalable platforms using
      <strong>Kubernetes</strong>, <strong>Terraform</strong>, and
      <strong>CI/CD pipelines</strong>, with strong focus on observability,
      DevSecOps, and cost optimization.
    </p>
    <p>
      I enjoy working on production systems, automating workflows, and improving
      how teams deploy and operate applications efficiently.
    </p>
  </div>

  {/* Experience */}
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10 grid gap-4">
    <TimeLineElement
      title="Cloud & DevOps Engineer · Enquire AI"
      subtitle="Apr 2026 – Present · Tunisia"
    >
      <ul class="list-disc ml-4">
        <li>
          Working on AWS infrastructure discovery, Kubernetes operations, and
          SOC 2 oriented security improvements.
        </li>
        <li>
          Auditing cloud infrastructure, IAM configurations, monitoring systems,
          and networking posture.
        </li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Cloud & DevOps Engineer · Day Truck"
      subtitle="May 2024 – Apr 2026 · Tunisia"
    >
      <ul class="list-disc ml-4">
        <li>
          Designed and deployed hybrid infrastructure (AWS + on-prem) for
          production systems.
        </li>
        <li>
          Automated infrastructure provisioning using <strong>Terraform</strong
          >, reducing setup time by ~60%.
        </li>
        <li>
          Managed Kubernetes workloads across environments (on-prem + EKS).
        </li>
        <li>
          Built CI/CD pipelines, reducing deployment time from hours to minutes
          and lowering incidents by ~25%.
        </li>
        <li>
          Implemented observability stack: Prometheus, Grafana, Loki,
          OpenTelemetry (on-prem) and AWS CloudWatch + X-Ray (EKS).
        </li>
        <li>
          Improved detection time by ~40% and increased security coverage ×3.
        </li>
        <li>Optimized cloud usage, reducing infrastructure costs by ~15%.</li>
        <li>
          Integrated Redis and Kafka to improve system performance and
          resilience.
        </li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Full Stack Developer · Vintonet"
      subtitle="Jan 2024 – Apr 2024 · Tunisia"
    >
      <ul class="list-disc ml-4">
        <li>
          Developed Mecafix, a SaaS platform with OCR, geolocation, and chat
          features.
        </li>
        <li>Deployed and managed the application in a cloud environment.</li>
        <li>Applied CI/CD practices to streamline delivery workflows.</li>
        <li>Improved backend performance and API security (~20% faster).</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Full Stack Developer (Freelance)"
      subtitle="Jul 2021 – Apr 2024 · Remote"
    >
      <ul class="list-disc ml-4">
        <li>Delivered <strong>10+ web applications</strong> end-to-end.</li>
        <li>
          Managed full lifecycle: development, deployment, and maintenance.
        </li>
        <li>
          Deployed applications on VPS/cloud environments with CI/CD workflows.
        </li>
        <li>Improved performance and SEO, increasing traffic by 20–25%.</li>
      </ul>
    </TimeLineElement>

    <TimeLineElement
      title="Web Developer · Hotel Iris Djerba"
      subtitle="Jul 2021 – Jul 2023 · Tunisia"
    >
      <ul class="list-disc ml-4">
        <li>
          Developed and maintained websites with focus on usability and
          performance.
        </li>
        <li>Improved online presence and user experience.</li>
      </ul>
    </TimeLineElement>
  </div>

  {/* Projects */}
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Projects</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li><strong>AWS Terraform Infrastructure Blueprint</strong></li>
    <li><strong>Secure Task API (DevSecOps)</strong></li>
    <li><strong>Platform Engineering IDP (Backstage + GitOps)</strong></li>
    <li><strong>GitOps & Observability Lab (Kubernetes)</strong></li>
    <li><strong>Serverless Data Pipeline (AWS)</strong></li>
  </ul>

  {/* Certifications */}
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>Certified Kubernetes Administrator (CKA)</li>
    <li>AWS Solutions Architect Associate (SAA-C03)</li>
    <li>Oracle Cloud Infrastructure DevOps Professional</li>
    <li>ISO 27001 Lead Auditor</li>
    <li>Microsoft Azure Fundamentals (AZ-900)</li>
    <li>GitHub Foundations</li>
    <li>Google Cybersecurity</li>
    <li>Meta Full-Stack Engineer</li>
  </ul>

  {/* Skills */}
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc md:columns-3 columns-2 mx-6 mb-8 gap-2">
    <li><strong>Cloud:</strong> AWS, Azure, GCP</li>
    <li><strong>Containers:</strong> Docker, Kubernetes, Helm</li>
    <li>
      <strong>CI/CD & GitOps:</strong> Jenkins, GitLab CI/CD, GitHub Actions, Argo
      CD
    </li>
    <li><strong>Infrastructure as Code:</strong> Terraform, Ansible</li>
    <li>
      <strong>Security (DevSecOps):</strong> Trivy, SonarQube, OWASP ZAP, Vault, IAM
    </li>
    <li>
      <strong>Observability:</strong> Prometheus, Grafana, Loki, OpenTelemetry, CloudWatch
    </li>
    <li>
      <strong>Networking:</strong> VPC, Load Balancers, Security Groups, DNS, VPN
    </li>
    <li>
      <strong>Programming:</strong> Python, Bash, Go, JavaScript/TypeScript
    </li>
    <li>
      <strong>Databases:</strong> PostgreSQL, MySQL, MongoDB, Redis, Kafka
    </li>
  </ul>

  {/* Education */}
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Engineering Degree — National Engineering School of Gabes"
      subtitle="2023 · Tunisia"
    />
  </div>

  {/* Languages */}
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Languages</div>
  </div>

  <ul class="list-disc mx-6 mb-8 grid gap-1">
    <li>Arabic — Native</li>
    <li>English — Professional</li>
    <li>French — Professional</li>
    <li>German — Intermediate (B1)</li>
  </ul>

  {/* Interests */}
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Interests</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-1">
    <li>Chess</li>
    <li>Technology Research</li>
    <li>Systems Optimization</li>
  </ul>
</BaseLayout>
