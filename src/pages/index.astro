---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";

const allPosts = await getCollection("blog");
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPosts = allPosts.slice(0, 3);

const featuredProjects = [
  {
    title: "AWS Terraform Infrastructure Blueprint",
    img: "/provisional.jpg",
    desc: "Production-ready AWS infrastructure blueprint using Terraform, covering core cloud building blocks such as networking, IAM, storage, and Kubernetes-ready patterns for scalable deployments.",
    url: "https://github.com/jaafar-harabi/aws-terraform-infra-blueprint",
    badge: "Featured",
    target: "_blank",
  },
  {
    title: "Secure Task API (DevSecOps)",
    img: "/provisional.jpg",
    desc: "Secure Node.js and TypeScript API with Docker, PostgreSQL, and a DevSecOps-focused delivery pipeline integrating secure build and deployment practices.",
    url: "https://github.com/jaafar-harabi/secure-task-api-devsecops",
    badge: "DevSecOps",
    target: "_blank",
  },
  {
    title: "Spring Boot + React Microservices DevSecOps Demo",
    img: "/provisional.jpg",
    desc: "Kubernetes-based microservices platform with CI/CD, security scanning, Helm charts, and observability, built to demonstrate modern platform engineering and cloud-native operations.",
    url: "https://github.com/jaafar-harabi/springboot-react-microservices-devsecops-demo",
    badge: "Cloud Native",
    target: "_blank",
  },
];
---

<BaseLayout sideBarActiveItemID="home">
  <section class="pb-12 mt-5">
    <p class="text-xl py-1">Hey there 👋</p>

    <h1 class="text-5xl font-bold">Jaafar Harabi — Cloud & DevOps Engineer</h1>

    <p class="text-3xl py-3 font-bold">
      Cloud &amp; DevOps Engineer · Platform Engineer
    </p>

    <div class="py-2 max-w-3xl leading-relaxed text-lg space-y-4">
      <p>
        Cloud &amp; DevOps Engineer with 3+ years of experience building and
        operating cloud-native and hybrid infrastructure across AWS and on-prem
        environments.
      </p>

      <p>
        I design reliable platforms using <strong>AWS</strong>, <strong
          >Kubernetes</strong
        >,
        <strong>Terraform</strong>, and <strong>CI/CD</strong>, with strong
        attention to security, observability, and cost optimization.
      </p>

      <p>
        I currently work on production systems at <strong>Enquire AI</strong>,
        focusing on AWS infrastructure, Kubernetes operations, cloud security,
        observability, and DevSecOps practices.
      </p>
    </div>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        class="btn"
        href="https://www.linkedin.com/in/jaafar-harabi/"
        target="_blank"
        rel="noreferrer"
      >
        Connect on LinkedIn
      </a>

      <a
        class="btn btn-outline"
        href="https://github.com/jaafar-harabi"
        target="_blank"
        rel="noreferrer"
      >
        View GitHub
      </a>

      <a
        class="btn btn-outline"
        href="/Jaafar-Harabi-Resume.pdf"
        target="_blank"
        rel="noreferrer"
      >
        Download Resume
      </a>
    </div>
  </section>

  <section class="mt-6">
    <h2 class="text-3xl w-full font-bold mb-4">Featured Projects</h2>

    {
      featuredProjects.map((project) => (
        <>
          <HorizontalCard
            title={project.title}
            img={project.img}
            desc={project.desc}
            url={project.url}
            badge={project.badge}
            target={project.target}
          />
          <div class="divider my-0" />
        </>
      ))
    }
  </section>

  <section class="mt-10">
    <h2 class="text-3xl w-full font-bold mb-5">Latest from blog</h2>

    {
      latestPosts.length === 0 ? (
        <div class="bg-base-200 border-l-4 border-secondary w-full p-4 min-w-full">
          <p class="font-bold">No posts yet</p>
          <p>Blog posts will appear here soon.</p>
        </div>
      ) : (
        <ul>
          {latestPosts.map((post) => (
            <>
              <HorizontalCard
                title={post.data.title}
                img={post.data.heroImage}
                desc={post.data.description}
                url={`/blog/${createSlug(post.data.title, post.slug)}`}
                target="_self"
                badge={post.data.badge}
                tags={post.data.tags}
              />
              <div class="divider my-0" />
            </>
          ))}
        </ul>
      )
    }

    <div class="mt-6 flex gap-4 flex-wrap items-center">
      <a
        href="https://medium.com/@jaafar-harabi"
        target="_blank"
        rel="noreferrer"
        class="link"
      >
        View more articles on Medium →
      </a>
    </div>
  </section>
</BaseLayout>
